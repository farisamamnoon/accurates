{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "./dist",        // 🎯 Redirects compiled .js files to /dist
    "rootDir": "./",           // 🎯 Tells tsc to look at the root for .ts files
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,

    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  }
}
